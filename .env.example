# ============================================
# PIXELVINE — Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values
# cp .env.example .env.local

# -------------------------------------------
# Convex (Required)
# -------------------------------------------
CONVEX_DEPLOYMENT=dev:your-deployment-name
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
CONVEX_SITE_URL=http://localhost:3000

# -------------------------------------------
# Authentication (Optional — mock auth works without these)
# -------------------------------------------
AUTH_GOOGLE_ID=your-google-oauth-client-id
AUTH_GOOGLE_SECRET=your-google-oauth-client-secret

# -------------------------------------------
# AI Providers — at least ONE is required
# -------------------------------------------

# Groq (Primary — free 100K tokens/day)
# Get your key at: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key

# Cerebras (Fallback — free 1M tokens/day)
# Get your key at: https://cloud.cerebras.ai
CEREBRAS_API_KEY=csk-your-cerebras-api-key

# Google Gemini (Style guide + critique + HiFi code gen)
# Get your key at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-api-key

# -------------------------------------------
# Optional Services
# -------------------------------------------

# Replicate (Image generation via Flux.1 Pro)
# Get your key at: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_your_replicate_token

# App URL (for internal API calls)
NEXT_PUBLIC_APP_URL=http://localhost:3000
